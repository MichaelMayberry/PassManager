<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.passmanager.AddAccountController"
      spacing="10"
      style="-fx-padding: 20; -fx-background-color: #1e293b; -fx-background-radius: 15;">

    <Label text="Add New Account"
           style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" />

    <TextField fx:id="usernameField" promptText="Username" />
    <PasswordField fx:id="passwordField" promptText="Password" />
    <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" />
    <TextField fx:id="platformField" promptText="Platform" />

    <Label fx:id="errorLabel" textFill="red" />

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#onCancelClick" />
        <Button text="Add" onAction="#onAddClick"
                style="-fx-background-color: #3b82f6; -fx-text-fill: white;" />
    </HBox>
</VBox>
