<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.passmanager.PasswordStrengthController"
      spacing="20"
      prefWidth="400"
      prefHeight="280"
      style="-fx-padding: 40; -fx-background-color: #1e293b;">

    <Label text="Password Strength Checker"
           style="-fx-text-fill: white; -fx-font-size: 20px;" />

    <PasswordField fx:id="passwordField" promptText="Enter password" prefHeight="40"
                   style="-fx-font-size: 14px;" />

    <Label fx:id="resultLabel" text="" style="-fx-font-size: 16px;" />

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#onCancelClick" prefHeight="38" prefWidth="90"
                style="-fx-font-size: 14px;" />
        <Button text="Check" onAction="#onCheckClick" prefHeight="38" prefWidth="90"
                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 14px;" />
    </HBox>
</VBox>
