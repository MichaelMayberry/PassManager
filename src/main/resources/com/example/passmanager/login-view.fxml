<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.passmanager.ModelController"
           style="-fx-background-color: #0f172a;">

    <VBox alignment="CENTER" spacing="20.0" maxWidth="400"
          style="-fx-padding: 40;">

        <Label text="Login"
               style="-fx-font-size: 26px; -fx-text-fill: white;" />

        <TextField fx:id="usernameField"
                   promptText="Username"
                   prefWidth="250" prefHeight="40"
                   style="-fx-font-size: 14px;" />

        <PasswordField fx:id="passwordField"
                       promptText="Password"
                       prefWidth="250" prefHeight="40"
                       style="-fx-font-size: 14px;" />

        <Button text="Login"
                onAction="#onLoginSubmit"
                prefWidth="250" prefHeight="45"
                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 16px;" />

        <Button text="⬅ Back"
                onAction="#onBackClick"
                prefWidth="250" prefHeight="40"
                style="-fx-background-color: transparent; -fx-text-fill: #9ca3af; -fx-font-size: 14px;" />

        <Label fx:id="statusLabel"
               textFill="#f87171"
               style="-fx-font-size: 13px;" />

    </VBox>
</StackPane>
