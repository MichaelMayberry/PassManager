<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.passmanager.MainScreenController"
            style="-fx-background-color: #0f172a;">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-padding: 20; -fx-background-color: #020617;">

            <Label text="PassManager Dashboard"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
        </HBox>
    </top>
    <center>
        <GridPane hgap="20" vgap="20" style="-fx-padding: 20;">

            <!-- Column sizing -->
            <columnConstraints>
                <ColumnConstraints percentWidth="40"/> <!-- Accounts (big) -->
                <ColumnConstraints percentWidth="30"/>
                <ColumnConstraints percentWidth="30"/>
            </columnConstraints>

            <!-- Row sizing -->
            <rowConstraints>
                <RowConstraints percentHeight="33"/>
                <RowConstraints percentHeight="33"/>
                <RowConstraints percentHeight="34"/>
            </rowConstraints>

            <!-- ACCOUNTS (LEFT SIDE - SPANS ALL ROWS) -->
            <VBox GridPane.rowIndex="0" GridPane.columnIndex="0"
                  GridPane.rowSpan="3"
                  spacing="10"
                  style="-fx-background-color: #1e293b; -fx-background-radius: 15; -fx-padding: 15;">

                <Label text="Accounts"
                       style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" />

                <ListView fx:id="accountsList"
                          VBox.vgrow="ALWAYS" />

                <Button text="+ Add Account"
                        onAction="#onAddAccountClick"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 8;" />
            </VBox>


            <!-- Row 0 -->
            <VBox GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-background-color: #1e293b; -fx-background-radius: 15; -fx-padding: 15;">
                <Label text="Alerts" style="-fx-text-fill: white;" />
            </VBox>

            <VBox GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-background-color: #1e293b; -fx-background-radius: 15; -fx-padding: 15;">
                <Label text="Tab 2" style="-fx-text-fill: white;" />
            </VBox>

            <!-- Row 1 -->
            <VBox GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-background-color: #1e293b; -fx-background-radius: 15; -fx-padding: 15;">
                <Label text="Tab 3" style="-fx-text-fill: white;" />
            </VBox>

            <VBox GridPane.rowIndex="1" GridPane.columnIndex="2" style="-fx-background-color: #1e293b; -fx-background-radius: 15; -fx-padding: 15;">
                <Label text="Tab 4" style="-fx-text-fill: white;" />
            </VBox>

            <!-- Row 2 -->
            <VBox GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-background-color: #1e293b; -fx-background-radius: 15; -fx-padding: 15;">
                <Label text="Tab 5" style="-fx-text-fill: white;" />
            </VBox>

            <VBox GridPane.rowIndex="2" GridPane.columnIndex="2" style="-fx-background-color: #1e293b; -fx-background-radius: 15; -fx-padding: 15;">
                <Label text="Tab 6" style="-fx-text-fill: white;" />
            </VBox>

        </GridPane>
    </center>

</BorderPane>
